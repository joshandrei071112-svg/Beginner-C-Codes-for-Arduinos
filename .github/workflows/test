name: C++ Code Checks

on:
  push:
    paths:
      - '**.cpp'
      - '**.h'
  pull_request:
    paths:
      - '**.cpp'
      - '**.h'

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Install cppcheck
        run: sudo apt-get install -y cppcheck
      
      - name: Run cppcheck on C++ files
        run: cppcheck --enable=all --suppress=missingIncludeSystem Variables/Integer.cpp
      
      - name: Check syntax with g++
        run: g++ -fsyntax-only Variables/Integer.cpp

  compile:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Install Arduino CLI
        run: |
          curl -fsSL https://raw.githubusercontent.com/arduino/arduino-cli/master/install.sh | sh
      
      - name: Compile Arduino sketch
        run: |
          arduino-cli compile --fqbn arduino:avr:uno Variables/Integer.cpp
